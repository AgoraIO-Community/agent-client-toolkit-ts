{
  "name": "agora-convo-ai-toolkit",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for Agora Conversational AI Toolkit",
  "scripts": {
    "build": "pnpm --filter @agora/conversational-ai-toolkit build && pnpm --filter @agora/conversational-ai-toolkit-react build",
    "test": "pnpm --filter @agora/conversational-ai-toolkit test && pnpm --filter @agora/conversational-ai-toolkit-react test",
    "test:coverage": "pnpm --filter @agora/conversational-ai-toolkit test -- --coverage && pnpm --filter @agora/conversational-ai-toolkit-react test -- --coverage",
    "clean": "pnpm -r clean"
  },
  "keywords": [
    "agora",
    "conversational-ai",
    "rtc",
    "rtm",
    "voice-assistant"
  ],
  "author": "Agora.io",
  "devDependencies": {
    "@agora-js/report": "^4.24.0",
    "agora-rtc-sdk-ng": "^4.23.4",
    "agora-rtm": "^2.2.1",
    "jszip": "^3.10.1"
  },
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgoraIO-Community/convo-ai-toolkit"
  },
  "bugs": {
    "url": "https://github.com/AgoraIO-Community/convo-ai-toolkit/issues"
  },
  "homepage": "https://github.com/AgoraIO-Community/convo-ai-toolkit#readme"
}
