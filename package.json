{
  "name": "agora-agent-client-toolkit",
  "version": "0.1.0",
  "private": true,
  "description": "Client-side SDK for adding Agora Conversational AI Engine features.",
  "scripts": {
    "build": "pnpm --filter agora-agent-client-toolkit build && pnpm --filter agora-agent-client-toolkit-react build",
    "test": "pnpm --filter agora-agent-client-toolkit test && pnpm --filter agora-agent-client-toolkit-react test",
    "test:coverage": "pnpm --filter agora-agent-client-toolkit test -- --coverage && pnpm --filter agora-agent-client-toolkit-react test -- --coverage",
    "lint": "eslint src/ packages/react/src/ apps/",
    "lint:fix": "eslint src/ packages/react/src/ apps/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"packages/react/src/**/*.ts\" \"apps/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"packages/react/src/**/*.ts\" \"apps/**/*.{ts,tsx}\"",
    "clean": "pnpm -r clean"
  },
  "keywords": [
    "agora",
    "conversational-ai",
    "rtc",
    "rtm",
    "voice-assistant"
  ],
  "author": "Agora.io",
  "devDependencies": {
    "@agora-js/report": "^4.24.0",
    "@eslint/js": "^10.0.1",
    "agora-rtc-sdk-ng": "^4.23.4",
    "agora-rtm": "^2.2.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jszip": "^3.10.1",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgoraIO-Conversational-AI/agent-client-toolkit-ts"
  },
  "bugs": {
    "url": "https://github.com/AgoraIO-Conversational-AI/agent-client-toolkit-ts/issues"
  },
  "homepage": "https://github.com/AgoraIO-Conversational-AI/agent-client-toolkit-ts#readme"
}
