{
  "name": "agora-voice-ai-demo",
  "version": "1.0.0",
  "description": "Demo application for agora-voice-ai package",
  "type": "module",
  "scripts": {
    "build": "tsc demo.ts --outDir dist --module es2020 --target es2020 --moduleResolution node --esModuleInterop",
    "start": "npm run build && node dist/demo.js",
    "dev": "npx vite",
    "serve": "npx http-server . -p 8080"
  },
  "dependencies": {
    "agora-voice-ai": "^1.8.0",
    "agora-rtc-sdk-ng": "^4.23.4",
    "agora-rtm": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vite": "^5.0.0"
  }
}
