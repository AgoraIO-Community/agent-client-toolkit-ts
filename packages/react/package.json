{
  "name": "@agora/conversational-ai-toolkit-react",
  "version": "0.1.0",
  "description": "React hooks for Agora Conversational AI Toolkit",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup && tsc --emitDeclarationOnly --skipLibCheck --outDir dist",
    "build:types": "tsc --emitDeclarationOnly --skipLibCheck --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@agora/conversational-ai-toolkit": ">=0.1.0",
    "agora-rtc-react": ">=2.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^24.1.3",
    "tsup": "^8.0.0",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9"
  },
  "keywords": [
    "agora",
    "conversational-ai",
    "react",
    "hooks",
    "voice-ai",
    "real-time",
    "rtc"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgoraIO-Community/convo-ai-toolkit"
  }
}
