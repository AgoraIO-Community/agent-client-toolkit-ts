{
  "name": "agora-agent-client-toolkit",
  "version": "1.2.0",
  "description": "Agora Agent Client Toolkit — real-time voice agent integration for web",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.ts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:interop": "tsc -p __typetests__/tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {},
  "peerDependencies": {
    "agora-rtc-sdk-ng": ">=4.23.4",
    "agora-rtm": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "agora-rtm": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "jszip": ">=3.0.0",
    "@agora-js/report": ">=4.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "jsdom": "^24.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.3",
    "@vitest/coverage-v8": "^2.1.9",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "agora",
    "voice-ai",
    "conversational-ai",
    "rtc",
    "rtm",
    "real-time-communication",
    "ai-agent",
    "voice-assistant",
    "transcription"
  ],
  "author": "Agora.io",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgoraIO-Conversational-AI/agent-client-toolkit-ts"
  },
  "bugs": {
    "url": "https://github.com/AgoraIO-Conversational-AI/agent-client-toolkit-ts/issues"
  },
  "homepage": "https://github.com/AgoraIO-Conversational-AI/agent-client-toolkit-ts#readme"
}
